{
  "name": "backend-graph-query",
  "version": "1.0.0",
  "packageManager": "yarn@1.22.22",
  "description": "Graph query engine for train-ticket microservices",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "NODE_OPTIONS='--inspect=0.0.0.0:9229' nodemon --exec ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --reporters=default --reporters=jest-junit",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose up dev",
    "docker:test": "docker-compose run --rm test",
    "docker:test:watch": "docker-compose run --rm test-watch",
    "docker:test:coverage": "docker-compose run --rm test-coverage",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v && rm -rf coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.11",
    "@types/supertest": "^2.0.12",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.5.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.4"
  }
}
