FROM node:22.12.0-alpine

WORKDIR /app

# Enable corepack for package manager consistency
RUN corepack enable

# Copy package files
COPY package*.json ./
COPY tsconfig.json ./
COPY jest.config.js ./

# Install dependencies
RUN npm ci && \
    npm cache clean --force

# Copy source code and tests
COPY src ./src
COPY tests ./tests
COPY data ./data

# Default command (can be overridden)
CMD ["npm", "test"]